# ─── Postgres ────────────────────────────────────────────────────────────────
# These are used by the db service to create the database,
# and by the api service to construct DATABASE_URL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=currency_converter

# ─── Exchange Rate Provider Keys ─────────────────────────────────────────────
# Get free keys at:
#   https://fixer.io             (note: free tier only supports EUR as base)
#   https://openexchangerates.org
#   https://currencyapi.com
FIXERIO_API_KEY=your_fixer_key_here
OPENEXCHANGE_APP_ID=your_openexchange_id_here
CURRENCYAPI_KEY=your_currencyapi_key_here

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Currency Converter API
DEBUG=true
